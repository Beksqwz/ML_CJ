# Copy this file to .env and add your real keys there. Never commit .env.
OPENWEATHER_API_KEY=
TOMTOM_API_KEY=
ML_SERVICE_API_KEY=change-me-before-deployment

# Optional live traffic collector settings.
TOMTOM_TRAFFIC_TOP_N=100
TOMTOM_TRAFFIC_INTERVAL_SECONDS=3600

# Live 24-hour inference and Future Intelligence worker (run separately from API).
ML_RUNTIME_DB_PATH=data/runtime/ml_service.sqlite3
ML_STRICT_LIVE_FEATURES=false
# Full synchronous prediction responses are bounded after persistence. The 16 MiB
# default accommodates the compact 3,968-row enriched contract, not raw features.
PREDICT_FULL_RESPONSE_MAX_BYTES=16777216
WEATHER_SEVERE_THRESHOLD=0.60
FUTURE_TRAFFIC_INTERVAL_MINUTES=10
FUTURE_WEATHER_INTERVAL_MINUTES=30
FUTURE_REPAIRS_INTERVAL_MINUTES=180
FUTURE_EVENTS_INTERVAL_MINUTES=720
FUTURE_TRAFFIC_TTL_MINUTES=20
FUTURE_WEATHER_TTL_MINUTES=90
FUTURE_REPAIRS_TTL_MINUTES=360
FUTURE_EVENTS_TTL_MINUTES=1440
FUTURE_RETRY_MAX_ATTEMPTS=3
FUTURE_RETRY_INITIAL_SECONDS=2
FUTURE_RETRY_MAX_SECONDS=30
FUTURE_RETRY_MULTIPLIER=2

# Optional API sync after each successful Future Layer scheduler cycle.  This
# creates a fresh prediction batch and a city action plan from the new context.
FUTURE_SYNC_API_URL=http://ml-api:7860
FUTURE_SYNC_API_TIMEOUT_SECONDS=180
FUTURE_SYNC_MAX_ACTIONS=10
FUTURE_SYNC_MINIMUM_PRIORITY=medium
